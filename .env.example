# Server
PORT=3000
AUTHENTICATED_USER_ID=alex-morgan
REQUIRE_AUTH=false
REQUIRE_2FA=true
SESSION_TTL_MS=28800000
AUTH_LOCKOUT_MS=900000
AUTH_MAX_FAILED_LOGINS=5
PENSIONS_STORAGE=sqlite
DATABASE_URL=
AGENT_SCHEDULER_ENABLED=true
AGENT_SCHEDULER_INTERVAL_MS=300000

# Default server-side provider. The user can also enter temporary API settings in the Assistant UI for testing.
ASSISTANT_PROVIDER=openai
DEFAULT_AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=groq/compound-mini

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_TITLE=Pension Plan Dashboard

# Optional local model route
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Optional custom OpenAI-compatible route
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=gpt-4o-mini
CUSTOM_AI_BASE_URL=

# Optional email alerts. The notification email entered in Settings is the destination.
# Configure one provider here or in your host environment. Do not commit real keys.
EMAIL_FROM="Pension Plan <alerts@example.com>"
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
RESEND_API_KEY=
SENDGRID_API_KEY=
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
AWS_SES_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
EMAIL_WEBHOOK_URL=
